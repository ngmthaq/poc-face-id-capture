{
  "name": "@ngmthaq20/react-face-id-capture",
  "version": "1.0.2",
  "description": "React component for face registration with real-time face detection and multi-angle capture",
  "type": "module",
  "main": "dist/react-face-id-capture.cjs",
  "module": "dist/react-face-id-capture.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/react-face-id-capture.js"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/react-face-id-capture.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "keywords": [
    "face",
    "face-detection",
    "face-registration",
    "biometric",
    "react",
    "camera",
    "face-capture"
  ],
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "homepage": "https://github.com/ngmthaq/poc-face-id-capture#readme",
  "bugs": {
    "url": "https://github.com/ngmthaq/poc-face-id-capture/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/ngmthaq/poc-face-id-capture.git"
  },
  "scripts": {
    "dev": "vite --host",
    "build": "tsc -b && vite build",
    "build:lib": "vite build && tsc -p tsconfig.build.json",
    "preview": "vite preview",
    "prepublishOnly": "npm run build:lib"
  },
  "peerDependencies": {
    "i18next": ">=23.0.0",
    "react": ">=18.0.0",
    "react-dom": ">=18.0.0",
    "react-i18next": ">=14.0.0"
  },
  "peerDependenciesMeta": {
    "i18next": {
      "optional": true
    },
    "react-i18next": {
      "optional": true
    }
  },
  "dependencies": {
    "@vladmandic/face-api": "^1.7.14"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-basic-ssl": "^2.3.0",
    "@vitejs/plugin-react": "^4.5.2",
    "i18next": "^25.10.9",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-i18next": "^16.6.6",
    "typescript": "~5.7.2",
    "vite": "^6.3.5"
  }
}

{
  "compilerOptions": {
    "target": "ES2020",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "types": ["vite/client"],
    "strict": true,
    "skipLibCheck": true,
    "declaration": true,
    "declarationDir": "dist",
    "emitDeclarationOnly": true,
    "outDir": "dist",
    "isolatedModules": true
  },
  "include": [
    "src/index.ts",
    "src/templates/**/*",
    "src/organisms/**/*",
    "src/molecules/**/*",
    "src/atoms/**/*",
    "src/shared/**/*"
  ]
}
